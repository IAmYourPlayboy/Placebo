# Server
HOST=0.0.0.0
PORT=3001
ENVIRONMENT=dev
RUST_LOG=placebo_api=debug,tower_http=debug

# PostgreSQL (PostGIS).
# docker-compose.dev.yml runs Postgres with trust auth, so the password is omitted in dev.
# In production set a real password and use postgres://user:pass@host:5432/db.
DATABASE_URL=postgres://placebo@localhost:5432/placebo
DB_MAX_CONNECTIONS=20

# Redis. docker-compose.dev.yml maps the container to 6380 to avoid clashing with
# another project's Redis that already listens on 6379.
REDIS_URL=redis://localhost:6380

# Auth
AUTH_SERVICE_URL=http://localhost:3002
JWT_SECRET=dev-secret-change-in-production

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=placebo-media
R2_PUBLIC_URL=https://assets.placebo.tv

# Limits
RATE_LIMIT_PER_MINUTE=60
MAX_ROOM_MEMBERS_FREE=4
MAX_ROOM_MEMBERS_PREMIUM=20
BOOST_TOKENS_PER_MONTH=4
